"""@MSG@"""

from __future__ import annotations

from dataclasses import dataclass


@dataclass
class @TITLE@:
    """@DESC@"""

@FIELDS@


_HARD = {
@HARD@
}


def _is(value: object, typ: str) -> bool:
    if typ == "int":
        return isinstance(value, int) and not isinstance(value, bool)
    if typ == "number":
        return isinstance(value, (int, float)) and not isinstance(value, bool)
    if typ == "string":
        return isinstance(value, str)
    if typ == "bool":
        return isinstance(value, bool)
    return False


def validate(obj: dict) -> list[str]:
    """Return HARD errors - corruption that makes the record unsafe to ingest."""
    errors: list[str] = []
    for name, typ in _HARD.items():
        if name not in obj:
            errors.append(f"missing hard-required field: {name}")
        elif not _is(obj[name], typ):
            errors.append(f"field {name} must be {typ}")
    return errors


def validate_full(obj: dict) -> tuple[list[str], list[str]]:
    """Return (hard_errors, warnings). The Run 0a proof has no warn fields."""
    return validate(obj), []
